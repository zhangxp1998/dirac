+class EntropyStoppingCriteria(StoppingCriteria):
+    """
+    This class can be used to stop generation whenever the Shannon entropy of the scores (logits) exceeds a certain
+    threshold for a given number of consecutive steps.
+
+    Args:
+        entropy_threshold (`float`):
+            The threshold for the Shannon entropy.
+        entropy_patience (`int`, *optional*, defaults to 1):
+            The number of consecutive steps the entropy must exceed `entropy_threshold` before generation is stopped.
+    """
+
+    def __init__(self, entropy_threshold: float, entropy_patience: int = 1):
+        self.entropy_threshold = entropy_threshold
+        self.entropy_patience = entropy_patience
+        self.consecutive_exceedances = None
+
+    @add_start_docstrings(STOPPING_CRITERIA_INPUTS_DOCSTRING)
+    def __call__(self, input_ids: torch.LongTensor, scores: torch.FloatTensor, **kwargs) -> torch.BoolTensor:
+        if scores is None or (isinstance(scores, (list, tuple)) and len(scores) == 0):
+            return torch.zeros(input_ids.shape[0], device=input_ids.device, dtype=torch.bool)
+
+        if isinstance(scores, (list, tuple)):
+            cur_scores = scores[-1]
+        else:
+            cur_scores = scores
+
+        # Shannon entropy
+        probs = F.softmax(cur_scores, dim=-1)
+        entropy = -torch.sum(probs * torch.log(probs + 1e-12), dim=-1)
+
+        if self.consecutive_exceedances is None:
+            self.consecutive_exceedances = torch.zeros(input_ids.shape[0], device=input_ids.device, dtype=torch.long)
+
+        exceeded = entropy > self.entropy_threshold
+        self.consecutive_exceedances = (self.consecutive_exceedances + 1) * exceeded
+
+        return self.consecutive_exceedances >= self.entropy_patience
+
