+			byUUID.set(gallery.identifier.uuid, gallery);
+			byID.set(gallery.identifier.id.toLowerCase(), gallery);
+		}
+		for (const installed of this.installed) {
+			if (installed.uuid) {
+				const gallery = byUUID.get(installed.uuid);
+				if (gallery) {
