diff --git a/src/transformers/generation/stopping_criteria.py b/src/transformers/generation/stopping_criteria.py
index b57136f534..0827c91582 100644
--- a/src/transformers/generation/stopping_criteria.py
+++ b/src/transformers/generation/stopping_criteria.py
@@ -492,6 +492,50 @@ class ConfidenceCriteria(StoppingCriteria):
         return False
 
 
+class EntropyStoppingCriteria(StoppingCriteria):
+    """
+    This class can be used to stop generation whenever the Shannon entropy of the model's scores (logits) exceeds a
+    threshold for a certain number of consecutive steps.
+
+    Args:
+        entropy_threshold (`float`):
+            The threshold for the Shannon entropy.
+        entropy_patience (`int`, *optional*, defaults to 1):
+            The number of consecutive steps the entropy must exceed the threshold before stopping.
+    """
+
+    def __init__(self, entropy_threshold: float, entropy_patience: int = 1):
+        self.entropy_threshold = entropy_threshold
+        self.entropy_patience = entropy_patience
+        self.consecutive_steps = None
+
+    @add_start_docstrings(STOPPING_CRITERIA_INPUTS_DOCSTRING)
+    def __call__(self, input_ids: torch.LongTensor, scores: torch.FloatTensor, **kwargs) -> torch.BoolTensor:
+        if scores is None:
+            return torch.full((input_ids.shape[0],), False, device=input_ids.device, dtype=torch.bool)
+
+        # Handle scores being a tuple (common in greedy_search/sample)
+        if isinstance(scores, tuple):
+            cur_scores = scores[-1]
+        else:
+            cur_scores = scores
+
+        probs = F.softmax(cur_scores, dim=-1)
+        log_probs = F.log_softmax(cur_scores, dim=-1)
+        entropy = -torch.sum(probs * log_probs, dim=-1)
+
+        if self.consecutive_steps is None or self.consecutive_steps.shape[0] != input_ids.shape[0]:
+            self.consecutive_steps = torch.zeros(input_ids.shape[0], device=input_ids.device, dtype=torch.long)
+
+        self.consecutive_steps = self.consecutive_steps.to(input_ids.device)
+
+        over_threshold = entropy > self.entropy_threshold
+        self.consecutive_steps[over_threshold] += 1
+        self.consecutive_steps[~over_threshold] = 0
+
+        return self.consecutive_steps >= self.entropy_patience
+
+
