+class EntropyStoppingCriteria(StoppingCriteria):
+    """
+    This class can be used to stop generation whenever the entropy of the logits exceeds a threshold for a given
+    number of steps.
+
+    Args:
+        entropy_threshold (`float`):
+            The threshold for the Shannon entropy of the logits.
+        entropy_patience (`int`, *optional*, defaults to 1):
+            The number of consecutive steps the entropy must exceed the threshold before stopping generation.
+    """
+
+    def __init__(self, entropy_threshold: float, entropy_patience: int = 1):
+        self.entropy_threshold = entropy_threshold
+        self.entropy_patience = entropy_patience
+        self.patience_counter = None
+
+    @add_start_docstrings(STOPPING_CRITERIA_INPUTS_DOCSTRING)
+    def __call__(self, input_ids: torch.LongTensor, scores: torch.FloatTensor, **kwargs) -> torch.BoolTensor:
+        if scores is None or (isinstance(scores, (list, tuple)) and len(scores) == 0):
+            return torch.zeros(input_ids.shape[0], device=input_ids.device, dtype=torch.bool)
+
+        current_scores = scores[-1] if isinstance(scores, (list, tuple)) else scores
+
+        # Calculate Shannon entropy: H = -sum(p * log(p))
+        log_probs = F.log_softmax(current_scores, dim=-1)
+        probs = torch.exp(log_probs)
+        entropy = -torch.sum(probs * log_probs, dim=-1)
+
+        if self.patience_counter is None or self.patience_counter.shape[0] != input_ids.shape[0]:
+            self.patience_counter = torch.zeros(input_ids.shape[0], device=input_ids.device, dtype=torch.long)
+
+        self.patience_counter = self.patience_counter.to(input_ids.device)
+
+        # Increment counter for sequences exceeding threshold, reset for others
+        exceeded = entropy > self.entropy_threshold
+        self.patience_counter = (self.patience_counter + 1) * exceeded
+
+        is_done = self.patience_counter >= self.entropy_patience
+        return is_done
+
