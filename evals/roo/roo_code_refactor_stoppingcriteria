+class EntropyStoppingCriteria(StoppingCriteria):
+    """
+    This class can be used to stop generation whenever the Shannon entropy of the scores (logits) exceeds a certain
+    threshold for a given number of consecutive steps.
+
+    Args:
+        entropy_threshold (`float`):
+            The threshold for the Shannon entropy of the scores (logits) at each step.
+        entropy_patience (`int`, *optional*, defaults to 1):
+            The number of consecutive steps for which the entropy must exceed `entropy_threshold` to stop generation.
+    """
+
+    def __init__(self, entropy_threshold: float, entropy_patience: int = 1):
+        self.entropy_threshold = entropy_threshold
+        self.entropy_patience = entropy_patience
+        self.consecutive_patience = None
+
+    @add_start_docstrings(STOPPING_CRITERIA_INPUTS_DOCSTRING)
+    def __call__(self, input_ids: torch.LongTensor, scores: torch.FloatTensor, **kwargs) -> torch.BoolTensor:
+        batch_size = scores.shape[0]
+        if self.consecutive_patience is None or self.consecutive_patience.shape[0] != batch_size:
+            self.consecutive_patience = torch.zeros(batch_size, device=scores.device, dtype=torch.long)
+
+        # Compute Shannon entropy: H = -sum(p * log(p))
+        probs = F.softmax(scores, dim=-1)
+        entropy = -torch.sum(probs * torch.log(probs + 1e-12), dim=-1)
+
+        high_entropy = entropy > self.entropy_threshold
+        self.consecutive_patience = torch.where(high_entropy, self.consecutive_patience + 1, 0)
+
+        return self.consecutive_patience >= self.entropy_patience
+
+
