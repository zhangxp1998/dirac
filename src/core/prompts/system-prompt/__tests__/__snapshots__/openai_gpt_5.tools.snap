  {
    "type": "function",
    "function": {
      "name": "read_file",
      "description": "Reads the complete contents of one or more files at the specified paths. Automatically extracts raw text from PDF and DOCX files. Returns the hash anchored lines that you can use with the edit_file tool. You can also specify a line range to read only a specific part of the file(s). Examples: { paths: [\"src/main.ts\", \"package.json\"] }, { paths: [\"src/main.ts\"] }, { paths: [\"src/main.ts\"], start_line: 10, end_line: 50 }, { paths: [\"src/main.ts\"], start_line: 100 }, { paths: [\"src/main.ts\"], end_line: 50 }. ONLY use line range when you only need a small number of lines in a large file.",
      "strict": false,
      "parameters": {
        "type": "object",
        "properties": {
          "paths": {
            "type": "array",
            "description": "An array of relative paths to the source files.",
            "items": {
              "type": "string"
            }
          },
          "start_line": {
            "type": "integer",
            "description": "Optional. If not supplied, output will start from line 1."
          },
          "end_line": {
            "type": "integer",
            "description": "Optional. If not supplied, the output will go until the last line"
          },
          "task_progress": {
            "type": "string",
            "description": "Updated task progress checklist."
          }
        },
        "required": [
          "paths"
        ],
        "additionalProperties": false
      }
    }
  },
  {
    "type": "function",
    "function": {
