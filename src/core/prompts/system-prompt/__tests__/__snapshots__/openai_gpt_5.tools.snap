            "description": "Optional array of 2-5 predefined answer options. DO NOT include options to toggle Act mode."
          },
          "task_progress": {
            "type": "string",
            "description": "Updated task progress checklist."
          }
        },
        "required": [
          "question"
        ],
        "additionalProperties": false
      }
    }
  },
